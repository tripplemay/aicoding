generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model HistoryItem {
  id        String   @id @default(cuid())
  toolId    String
  title     String
  input     String
  output    String
  createdAt DateTime @default(now())
}
